<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.blog.mapper.CategoryMapper">

    <resultMap id="CategoryResultMap" type="com.example.blog.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="baseColumns">
        id, name, description, sort_order, created_at
    </sql>

    <select id="selectById" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/> FROM category WHERE id = #{id}
    </select>

    <select id="selectByName" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/> FROM category WHERE name = #{name}
    </select>

    <select id="selectAll" resultMap="CategoryResultMap">
        SELECT <include refid="baseColumns"/> FROM category ORDER BY sort_order ASC, id ASC
    </select>

    <select id="countArticlesByCategoryId" resultType="int">
        SELECT COUNT(*) FROM article WHERE category_id = #{categoryId}
    </select>

    <insert id="insert" parameterType="com.example.blog.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, description, sort_order) VALUES (#{name}, #{description}, #{sortOrder})
    </insert>

    <update id="update" parameterType="com.example.blog.entity.Category">
        UPDATE category
        SET name = #{name}, description = #{description}, sort_order = #{sortOrder}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM category WHERE id = #{id}
    </delete>

</mapper>
